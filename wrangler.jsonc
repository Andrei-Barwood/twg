{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "twg",
  "compatibility_date": "2026-06-06",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  },
  "build": {
    "command": "mkdir -p public && cp *.html public/ && cp -r assets public/"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
